# Meta Messenger Platform API mode
VERIFY_TOKEN=dev-verify-token
PAGE_ACCESS_TOKEN=
APP_SECRET=
GRAPH_API_VERSION=v25.0
AUTO_REPLY_ENABLED=true
AUTO_REPLY_MODE=rules
REPLY_RULES_PATH=config/reply_rules.example.json
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_SYSTEM_PROMPT=あなたはFacebookページの丁寧な一次受付担当です。短く自然に日本語で返信してください。
LOG_LEVEL=INFO

# Playwright browser UI mode. No access token is used in this mode.
UI_BOT_INBOX_URL=https://www.facebook.com/messages/t/
UI_BOT_USER_DATA_DIR=.playwright/facebook-profile
UI_BOT_HEADLESS=false
UI_BOT_POLL_SECONDS=5
UI_BOT_MAX_REPLIES_PER_RUN=10
UI_BOT_DRY_RUN=true
UI_BOT_REPLY_RULES_PATH=config/reply_rules.example.json
UI_BOT_LOGIN_WAIT_SECONDS=60

# Selectors are intentionally configurable because Facebook UI markup changes often.
# Separate multiple selectors with ||
UI_BOT_THREAD_SELECTORS=div[aria-label*="未読"]||div[aria-label*="Unread"]||[role="row"][aria-label*="未読"]||[role="row"][aria-label*="Unread"]
UI_BOT_MESSAGE_TEXT_SELECTORS=[data-testid="message-container"] [dir="auto"]||[role="main"] [dir="auto"]
UI_BOT_COMPOSER_SELECTORS=div[role="textbox"][contenteditable="true"][aria-label*="メッセージ"]||div[role="textbox"][contenteditable="true"][aria-label*="Message"]||div[role="textbox"][contenteditable="true"]
UI_BOT_SEND_BUTTON_SELECTORS=div[aria-label="送信"]||div[aria-label="Send"]||[data-testid="send"]
